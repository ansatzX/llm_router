# LLM Router Configuration

# Base URL of the LLM backend (e.g., SGLang, vLLM, or any OpenAI-compatible API)
LLM_BASE_URL=http://localhost:8000

# API Key for the LLM backend (if required, leave empty if not needed)
LLM_API_KEY=

# Port for the Flask router (default: 5001)
FLASK_PORT=5001

# Maximum rollback retries when tool call parsing fails (default: 3)
# Set to 0 to disable rollback
MAX_ROLLBACK_RETRIES=3

# Default parameter values - MiroThinker recommendations for optimal tool-calling
# Applied when client doesn't specify, can be overridden here
DEFAULT_TEMPERATURE=1.0
DEFAULT_TOP_P=0.95
DEFAULT_REPETITION_PENALTY=1.05
DEFAULT_MAX_TOKENS=16384

# Fine-grained timeout configuration (in seconds)
# These control different aspects of HTTP request behavior

# Connect timeout: Time to establish TCP connection (default: 5s)
# Should be short for fast failure detection
LLM_CONNECT_TIMEOUT=5

# Read timeout: Maximum time without receiving data (default: 120s)
# This is NOT total request time! It's the max idle time between data chunks.
# For slow models or long reasoning, increase this value.
# - Fast models: 60s
# - Normal models: 120s (default)
# - Slow/reasoning models: 300s
LLM_READ_TIMEOUT=120

# Write timeout: Time to send request data (default: 30s)
# Usually doesn't need to be changed
LLM_WRITE_TIMEOUT=30

# Pool timeout: Time to wait for connection from pool (default: 10s)
LLM_POOL_TIMEOUT=10

# Health check timeout (in seconds)
# How long to wait for backend health check response (default: 3s)
# Short timeout allows quick detection during frequent polling by deployment platforms
# Used by /health and /metrics endpoints to verify backend readiness
HEALTH_CHECK_TIMEOUT=3
